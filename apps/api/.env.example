# @sitewright/api environment

# libsql/SQLite location (file: URL). Default: file:./data/sitewright.db
DATABASE_URL=file:/data/sitewright.db

# HTTP port
PORT=2002

# REQUIRED in production: secret used to sign the session cookie.
COOKIE_SECRET=

# Set to "true" only when served behind HTTPS/TLS (adds the Secure cookie flag).
# Leave unset for the HTTP DinD preview.
COOKIE_SECURE=false

# --- First-boot bootstrap + registration policy --------------------------------
# Public registration is CLOSED by default (invitation-only). To open self-signup,
# set this to "true". When closed, the only ways in are the seeded admin below and
# org invites — a fresh instance always seeds a bootstrap admin (defaults below), so
# a closed instance is reachable on first boot out of the box.
SW_OPEN_REGISTRATION=false

# The bootstrap super-admin, seeded once when the instance has no users. This email
# is also added to the instance-admin allowlist (SW_ADMIN_EMAILS). Defaults to
# admin@sitewright.example when unset.
SW_ADMIN_EMAIL=

# The seeded admin's password. If unset, the FIXED default "123456" is used and a
# WARNING is printed to stderr — change it after first login, or set your own here
# before first boot.
SW_ADMIN_PASSWORD=

# Comma-separated allowlist of instance-admin emails (global settings: SMTP, hCaptcha,
# enabled web-form mail modes). SW_ADMIN_EMAIL is always included automatically.
SW_ADMIN_EMAILS=

# --- Online AI (agency-funded) -------------------------------------------------
# The single global Anthropic API key that funds in-editor AI generation. When
# unset, the AI endpoints return 501 (feature disabled). Keep this server-side
# only — it is never sent to clients or written to logs.
SW_AI_API_KEY=

# Optional: pin the funded model (default: claude-haiku-4-5-20251001). Clients
# cannot override this — it bounds per-call cost.
SW_AI_MODEL=claude-haiku-4-5-20251001

# Monthly token caps that meter usage against the shared key so no single org or
# user drains the budget. Positive integers; UNSET or any non-positive value
# means UNLIMITED (a startup warning is logged for set-but-invalid values).
SW_AI_ORG_MONTHLY_TOKENS=
SW_AI_USER_MONTHLY_TOKENS=
