# @sitewright/api environment
#
# A deployed instance needs almost NO env: it auto-seeds an admin, defaults to a HARDENED posture, and is
# reconfigured from the in-app System Settings. In practice you set TWO things — where data lives
# (SW_DATA_DIR) and where the instance is reached (SW_PUBLIC_URL) — and the rest is derived. Everything
# below is optional.

# ONE persistent data directory — holds the SQLite DB, media, published sites + preview builds. Mount a
# single volume here to persist an instance. Default: ./data (the Docker image sets /app/data). Every
# sub-root is derived from this; there are no separate MEDIA_ROOT/PUBLISH_ROOT/... knobs.
SW_DATA_DIR=/app/data

# The public https URL the instance is served at (behind your reverse proxy / TLS). Setting this is the
# single knob that hardens a TLS deployment: it turns ON Secure cookies + the __Host- cookie prefix +
# HSTS, and it becomes the WebAuthn/passkey relying-party origin. Also baked into exported forms as the
# absolute submission endpoint. Leave unset for a local/plain-HTTP instance.
# NOTE: this pins the WebAuthn RP to one origin — if the instance is reached via MULTIPLE hostnames, set
# SW_WEBAUTHN_RP_ID / SW_WEBAUTHN_ORIGIN explicitly (or leave SW_PUBLIC_URL unset to derive per-request).
# SW_PUBLIC_URL=https://sitewright.example.com

# Runtime mode. UNSET defaults to `production` (hardened: structured logs, forced default-password change,
# Secure-cookie warnings). Set to `development` only for a local, non-public instance.
# NODE_ENV=production

# Set to "true" when running behind a reverse proxy so per-IP rate limits key on the real client IP
# (X-Forwarded-For) instead of collapsing every client onto the proxy's IP. Accepts true/false or a
# comma-separated IP/CIDR allowlist.
# TRUST_PROXY=true

# HTTP port the server listens on. Default: 2002 (the Docker image sets 80).
PORT=2002

# Optional: override the DB location explicitly (a libsql/SQLite file: URL). Normally NOT needed — the
# DB defaults to <SW_DATA_DIR>/sitewright.db.
# DATABASE_URL=

# OPTIONAL: a pinned session-cookie signing secret. If unset, one is auto-generated on first boot and
# persisted, and can be rotated from System Settings. Set this to PIN it (e.g. to share across replicas);
# while set, it overrides the persisted value and in-app rotation is disabled.
COOKIE_SECRET=

# Optional OVERRIDE for the Secure cookie flag. Normally derived from SW_PUBLIC_URL (https ⇒ on); set to
# "true"/"false" only to force it (e.g. TLS terminated somewhere SW_PUBLIC_URL doesn't capture).
# COOKIE_SECURE=

# --- First-boot bootstrap admin ------------------------------------------------
# Public registration is CLOSED by default (invitation-only); there is no env to open it — an admin
# enables self-signup at runtime in System Settings. The instance auto-seeds ONE admin on first boot;
# admin is a persisted user role (no email allowlist), and further admins are granted via in-app invites.

# Optional: override the seeded admin's email. Default: admin@sitewright.example.
SW_ADMIN_EMAIL=

# Optional: the seeded admin's password. If unset, the FIXED default "123456" is used and a WARNING is
# printed to stderr — in production the admin is FORCED to change it on first login. Set your own here
# before first boot to skip that.
SW_ADMIN_PASSWORD=

# REQUIRED to use saved deploy targets + stored secrets (SMTP/OAuth/stock): a 32-byte base64 key that
# encrypts those credentials at rest. Kept env-only ON PURPOSE — out of the DB, so a DB dump can't
# decrypt. Without it, those secret-bearing features stay disabled (the rest of the app works).
SW_ENCRYPTION_KEY=

# --- Online AI (agency-funded) -------------------------------------------------
# The single global Anthropic API key that funds in-editor AI generation. When
# unset, the AI endpoints return 501 (feature disabled). Keep this server-side
# only — it is never sent to clients or written to logs.
SW_AI_API_KEY=

# Optional: pin the funded model (default: claude-haiku-4-5-20251001). Clients
# cannot override this — it bounds per-call cost.
SW_AI_MODEL=claude-haiku-4-5-20251001

# Monthly token caps that meter usage against the shared key so no single org or
# user drains the budget. Positive integers; UNSET or any non-positive value
# means UNLIMITED (a startup warning is logged for set-but-invalid values).
SW_AI_ORG_MONTHLY_TOKENS=
SW_AI_USER_MONTHLY_TOKENS=
