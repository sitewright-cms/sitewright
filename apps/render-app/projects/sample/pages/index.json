{
  "id": "home",
  "path": "",
  "title": "Home",
  "seo": { "description": "Northwind Studio — fast, beautiful websites built with Sitewright." },
  "root": {
    "id": "root",
    "type": "Section",
    "props": { "tone": "surface" },
    "children": [
      { "id": "hdr-slot", "type": "Section", "partialRef": "site-header" },
      {
        "id": "hero",
        "type": "Hero",
        "props": {
          "title": "We build fast, beautiful websites",
          "subtitle": "Northwind Studio crafts high-performance sites with Sitewright.",
          "ctaText": "Get in touch",
          "ctaHref": "/about"
        }
      },
      {
        "id": "hero-image",
        "type": "Image",
        "props": { "src": "hero.png", "alt": "Northwind Studio", "priority": true }
      },
      { "id": "features-heading", "type": "Heading", "props": { "text": "What you get", "level": 2 } },
      {
        "id": "features-grid",
        "type": "Grid",
        "props": { "columns": 3 },
        "binding": { "dataset": "features", "mode": "list", "query": { "sort": { "field": "title", "dir": "asc" } } },
        "children": [
          {
            "id": "feature-card",
            "type": "Card",
            "children": [
              { "id": "feature-title", "type": "Heading", "props": { "level": 3, "textField": "title" } },
              { "id": "feature-body", "type": "RichText", "props": { "textField": "body" } }
            ]
          }
        ]
      },
      { "id": "ftr-slot", "type": "Section", "partialRef": "site-footer" }
    ]
  }
}
