---
import type { PageNode } from '@sitewright/schema';

interface Props {
  node: PageNode;
}
// node is accepted for a uniform component contract even when unused.
const { node: _node } = Astro.props;
---

<div class="flex flex-col gap-3 rounded-card bg-base-100 p-6 shadow-sm ring-1 ring-black/5">
  <slot />
</div>
