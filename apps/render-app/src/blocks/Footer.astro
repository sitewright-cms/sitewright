---
import type { PageNode } from '@sitewright/schema';

interface Props {
  node: PageNode;
}
const { node } = Astro.props;
const text = typeof node.props?.text === 'string' ? node.props.text : '';
---

<footer class="w-full border-t border-slate-100 bg-surface">
  <div class="mx-auto max-w-5xl px-6 py-8 text-sm text-muted">
    {text}<slot />
  </div>
</footer>
