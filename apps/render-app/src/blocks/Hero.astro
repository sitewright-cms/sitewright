---
import type { Entry, PageNode } from '@sitewright/schema';
import { textProp, urlProp } from './props';

interface Props {
  node: PageNode;
  entry?: Entry;
}
const { node, entry } = Astro.props;
const props = node.props ?? {};
const title = textProp(props, entry, 'title');
const subtitle = textProp(props, entry, 'subtitle');
const ctaText = textProp(props, entry, 'ctaText');
const ctaHref = urlProp(props, entry, 'ctaHref', '#');
---

<div class="mx-auto max-w-3xl py-10 text-center">
  {title && <h1 class="font-heading text-5xl font-extrabold tracking-tight text-base-content">{title}</h1>}
  {subtitle && <p class="mt-6 text-lg text-muted">{subtitle}</p>}
  {
    ctaText && (
      <a
        href={ctaHref}
        class="mt-8 inline-block rounded-card bg-primary px-6 py-3 font-semibold text-white"
      >
        {ctaText}
      </a>
    )
  }
  <slot />
</div>
