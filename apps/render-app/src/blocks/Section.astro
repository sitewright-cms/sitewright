---
import type { PageNode } from '@sitewright/schema';

interface Props {
  node: PageNode;
}
const { node } = Astro.props;
const tone = typeof node.props?.tone === 'string' ? node.props.tone : 'surface';
const toneClass =
  tone === 'primary'
    ? 'bg-primary text-white'
    : tone === 'muted'
      ? 'bg-slate-50 text-base-content'
      : 'bg-base-100 text-base-content';
---

<section class={`w-full px-6 py-12 ${toneClass}`}>
  <div class="mx-auto flex max-w-5xl flex-col gap-10">
    <slot />
  </div>
</section>
