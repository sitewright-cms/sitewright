---
import '../styles/global.css';
import type { Project } from '@sitewright/schema';

interface Props {
  title: string;
  // Flat SEO/meta fields (formerly the `page.seo` object). The page title IS the document title.
  description?: string;
  canonical?: string;
  noindex?: boolean;
  brandCss: string;
  project: Project;
}

const { title, description, canonical, noindex, brandCss, project } = Astro.props;
const pageTitle = `${title} · ${project.name}`;
---

<!doctype html>
<html lang={project.settings.defaultLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex" />}
    {(project.identity.icon ?? project.identity.favicon) && (
      <link rel="icon" href={project.identity.icon ?? project.identity.favicon} />
    )}
    {/* Per-project brand tokens -> CSS custom properties (single source of truth). */}
    <style set:html={brandCss}></style>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <slot />
  </body>
</html>
