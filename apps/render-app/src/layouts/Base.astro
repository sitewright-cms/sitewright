---
import '../styles/global.css';
import type { Project, Seo } from '@sitewright/schema';

interface Props {
  title: string;
  seo?: Seo;
  brandCss: string;
  project: Project;
}

const { title, seo, brandCss, project } = Astro.props;
const pageTitle = seo?.title ?? `${title} · ${project.name}`;
---

<!doctype html>
<html lang={project.settings.defaultLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {seo?.description && <meta name="description" content={seo.description} />}
    {seo?.canonical && <link rel="canonical" href={seo.canonical} />}
    {seo?.noindex && <meta name="robots" content="noindex" />}
    {(project.identity.icon ?? project.identity.favicon) && (
      <link rel="icon" href={project.identity.icon ?? project.identity.favicon} />
    )}
    {/* Per-project brand tokens -> CSS custom properties (single source of truth). */}
    <style set:html={brandCss}></style>
  </head>
  <body class="min-h-screen bg-surface text-ink">
    <slot />
  </body>
</html>
