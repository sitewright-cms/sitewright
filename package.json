{
  "name": "sitewright-monorepo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Sitewright — OSS website development platform for web-development agencies.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "set-version": "node scripts/set-version.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.14.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@tailwindcss/oxide", "sharp"],
    "overrides": {
      "hono@<4.12.25": ">=4.12.25",
      "nodemailer@<9.0.1": ">=9.0.1"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-gv7w-rqvm-qjhr",
        "GHSA-hmw2-7cc7-3qxx",
        "GHSA-fx2h-pf6j-xcff"
      ]
    }
  }
}
