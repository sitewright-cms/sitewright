{
  "name": "@sitewright/blocks",
  "version": "0.2.0",
  "description": "Framework-free block library for Sitewright: block descriptors (palette + prop-field metadata) and a pure, XSS-safe HTML renderer that mirrors the published Astro output. Shared by the editor and the live-preview endpoint.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./google-fonts-catalog": {
      "types": "./dist/google-fonts-catalog.d.ts",
      "import": "./dist/google-fonts-catalog.js"
    },
    "./url": {
      "types": "./dist/url.d.ts",
      "import": "./dist/url.js"
    },
    "./control": {
      "types": "./dist/control.d.ts",
      "import": "./dist/control.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "gen:brand-icons": "node scripts/gen-brand-icons.mjs",
    "gen:brand-icons:check": "node scripts/gen-brand-icons.mjs && git diff --exit-code src/brand-icons.ts",
    "gen:lucide-icons": "node scripts/gen-lucide-icons.mjs",
    "gen:lucide-icons:check": "node scripts/gen-lucide-icons.mjs && git diff --exit-code src/icons.ts",
    "gen:google-fonts": "node scripts/gen-google-fonts.mjs",
    "gen:flag-icons": "node scripts/gen-flag-icons.mjs",
    "gen:flag-icons:check": "node scripts/gen-flag-icons.mjs && git diff --exit-code src/flag-icons.ts",
    "gen:vendor": "node scripts/gen-vendor.mjs",
    "gen:vendor:check": "node scripts/gen-vendor.mjs && git diff --exit-code src/vendor"
  },
  "dependencies": {
    "@sitewright/core": "workspace:*",
    "@sitewright/schema": "workspace:*",
    "dom-serializer": "^2.0.0",
    "domhandler": "^5.0.3",
    "domutils": "^3.2.2",
    "handlebars": "^4.7.9",
    "htmlparser2": "^9.1.0",
    "sanitize-html": "^2.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/sanitize-html": "^2.13.0",
    "@vitest/coverage-v8": "^4.1.8",
    "circle-flags": "^2.8.3",
    "embla-carousel": "8.6.0",
    "embla-carousel-auto-height": "8.6.0",
    "embla-carousel-auto-scroll": "8.6.0",
    "embla-carousel-autoplay": "8.6.0",
    "embla-carousel-fade": "8.6.0",
    "embla-carousel-wheel-gestures": "8.1.0",
    "esbuild": "^0.28.1",
    "flag-icons": "^7.5.0",
    "glightbox": "3.3.1",
    "lucide-static": "^0.544.0",
    "simple-icons": "^16.21.0",
    "smartphoto": "1.6.5",
    "typescript": "^5.7.2",
    "vanilla-calendar-pro": "3.1.0",
    "vitest": "^4.1.8"
  }
}
