{
  "name": "@sitewright/blocks",
  "version": "0.0.0",
  "description": "Framework-free block library for Sitewright: block descriptors (palette + prop-field metadata) and a pure, XSS-safe HTML renderer that mirrors the published Astro output. Shared by the editor and the live-preview endpoint.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sitewright/core": "workspace:*",
    "@sitewright/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
