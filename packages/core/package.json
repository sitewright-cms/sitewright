{
  "name": "@sitewright/core",
  "version": "0.2.0",
  "description": "Pure domain logic for Sitewright: immutable block-tree operations, partial resolution, binding resolution, and project validation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sitewright/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
