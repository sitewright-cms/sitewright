{
  "name": "@sitewright/image-pipeline",
  "version": "0.1.0",
  "description": "Build-time image optimization for Sitewright: responsive AVIF/WebP variants, LQIP placeholders, and srcset manifests via sharp.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
