{
  "name": "@sitewright/tailwind",
  "version": "0.1.0",
  "description": "Publish-time Tailwind utility-CSS compiler: scans rendered HTML and emits a minimal stylesheet with brand tokens mapped into the theme.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sitewright/schema": "workspace:*",
    "@tailwindcss/node": "^4.3.0",
    "@tailwindcss/oxide": "^4.3.0",
    "daisyui": "~5.5",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
